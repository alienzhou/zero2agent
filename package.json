{
  "name": "zero2agent",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "From Zero to Agent - A hands-on AI Agent development tutorial",
  "author": "zhouhongxuan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:alienzhou/zero2agent.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "eslint packages --ext .ts,.tsx",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "format": "prettier --write 'packages/**/*.ts'",
    "format:check": "prettier --check 'packages/**/*.ts'",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.2.0",
    "typescript-eslint": "^8.0.0"
  }
}
