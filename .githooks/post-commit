#!/bin/bash

# Zero2Agent Post-Commit Hook
# 检查 commit message 格式 + 提示索引文件更新

# 获取最新 commit message 的第一行
COMMIT_MSG=$(git log -1 --pretty=%s)

# 检查格式：Story commit [Exx-Sxxx] 或 [S000]，或标准 Conventional Commit
IS_STORY_COMMIT=false
IS_CONVENTIONAL=false

if [[ "$COMMIT_MSG" =~ ^\[E[0-9]{2}-S[0-9]{3}\] ]] || [[ "$COMMIT_MSG" =~ ^\[S000\] ]]; then
    IS_STORY_COMMIT=true
elif [[ "$COMMIT_MSG" =~ ^(feat|fix|docs|refactor|test|chore|style|perf|ci|build|revert)(\(.*\))?:\ .+ ]]; then
    IS_CONVENTIONAL=true
fi

if [[ "$IS_STORY_COMMIT" == false ]] && [[ "$IS_CONVENTIONAL" == false ]]; then
    echo ""
    echo "╔════════════════════════════════════════════════════════════════════╗"
    echo "║  ⚠️  Commit Message 格式不符合规范！                                 ║"
    echo "╠════════════════════════════════════════════════════════════════════╣"
    echo "║                                                                    ║"
    echo "║  当前 message: $COMMIT_MSG"
    echo "║                                                                    ║"
    echo "║  Story Commit:                                                     ║"
    echo "║    [E01-S001] type(scope): description                             ║"
    echo "║                                                                    ║"
    echo "║  非 Story Commit:                                                  ║"
    echo "║    type(scope): description                                        ║"
    echo "╚════════════════════════════════════════════════════════════════════╝"
    echo ""
fi

echo ""
echo "╔════════════════════════════════════════════════════════════════════╗"
echo "║  ✅ Commit 完成！请检查以下索引文件是否需要更新：                      ║"
echo "╠════════════════════════════════════════════════════════════════════╣"
echo "║                                                                    ║"
echo "║  [ ] CHANGELOG.md      - 添加本次变更条目（必须）                    ║"
echo "║  [ ] specs/README.md   - 新建 Spec 时更新                           ║"
echo "║  [ ] retros/README.md  - 新建复盘时更新                              ║"
echo "║                                                                    ║"
echo "╠════════════════════════════════════════════════════════════════════╣"
echo "║  如需补充更新，请执行：                                              ║"
echo "║                                                                    ║"
echo "║    1. 编辑需要更新的文件                                            ║"
echo "║    2. git add <files>                                              ║"
echo "║    3. git commit --amend --no-edit                                 ║"
echo "║                                                                    ║"
echo "╚════════════════════════════════════════════════════════════════════╝"
echo ""
